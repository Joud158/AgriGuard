PORT=4000
JWT_SECRET=replace-with-a-long-random-secret-for-local-development
JWT_EXPIRES_IN=7d
INVITATION_TTL_HOURS=72
EMAIL_VERIFICATION_TTL_HOURS=24
PASSWORD_RESET_TTL_MINUTES=30
MFA_CHALLENGE_TTL_MINUTES=10
MFA_ISSUER=AgriGuard
CORS_ORIGIN=http://localhost:5173
FRONTEND_BASE_URL=http://localhost:5173
SHOW_INVITE_PREVIEW_LINK=true
SHOW_PASSWORD_RESET_PREVIEW_LINK=false

EMAIL_ENABLED=false
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-google-app-password
EMAIL_FROM=AgriGuard <your-email@gmail.com>
EMAIL_REPLY_TO=your-email@gmail.com
SHOW_PASSWORD_RESET_PREVIEW_LINK=false

PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=eu

AI_PROVIDER=local
LOCAL_AI_SERVICE_URL=http://127.0.0.1:8105
LOCAL_VISION_MODEL=wambugu71/crop_leaf_diseases_vit
LOCAL_VISION_MODEL_PATH=../local-ai-service/models/crop_leaf_diseases_vit
LOCAL_TRANSCRIPTION_MODEL=openai/whisper-tiny
LOCAL_NLP_MODE=heuristic
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4.1-mini
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_NLP_MODEL=gpt-4o-mini

SATELLITE_PROVIDER=sentinel_hub
SENTINEL_CLIENT_ID=
SENTINEL_CLIENT_SECRET=
SENTINEL_TOKEN_URL=https://identity.dataspace.copernicus.eu/auth/realms/CDSE/protocol/openid-connect/token
SENTINEL_STATS_URL=https://sh.dataspace.copernicus.eu/api/v1/statistics
# Optional live field boundaries. Use WGS84 bbox: [minLon,minLat,maxLon,maxLat].
# Example: [{"name":"North Olive Block","crop":"Olives","bbox":[35.45,33.80,35.46,33.81]}]
SATELLITE_FIELDS_JSON=
NASA_POWER_ENABLED=true
